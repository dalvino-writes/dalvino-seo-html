{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/services/layout,_N_T_/services/page,_N_T_/services"},"segmentPaths":["/_tree","/_full","/services/__PAGE__","/services","/_index","/_head"]},"html":"<!DOCTYPE html><!--qDi_Q2houFvzo7kJcV_0o--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/e2c58c14e218d743.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0e1d4a177458003f.js\"/><script src=\"/_next/static/chunks/f2f58a7e93290fbb.js\" async=\"\"></script><script src=\"/_next/static/chunks/b511d225fa117d63.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-941d9372f54a64f6.js\" async=\"\"></script><script src=\"/_next/static/chunks/ad1e28e5e562f50f.js\" async=\"\"></script><script src=\"/_next/static/chunks/79a7563441b01c6b.js\" async=\"\"></script><script src=\"/_next/static/chunks/559c65e19c6c7a5a.js\" async=\"\"></script><script src=\"/_next/static/chunks/ff1a16fafef87110.js\" async=\"\"></script><script src=\"/_next/static/chunks/d2be314c3ece3fbe.js\" async=\"\"></script><script src=\"/_next/static/chunks/14739d48f08353d6.js\" async=\"\"></script><script src=\"/_next/static/chunks/44a5e35cc6a50262.js\" async=\"\"></script><script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=G-EQMQGSTNR4\"></script><link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\"/><link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\"/><link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\"/><link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon.png\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><title>D.digitactics · Organic Authority Architecture for Healthcare SaaS</title><meta name=\"description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><meta name=\"author\" content=\"D.digitactics\"/><meta property=\"og:title\" content=\"D.digitactics · Organic Authority Architecture for Healthcare SaaS\"/><meta property=\"og:description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@digitactics\"/><meta name=\"twitter:title\" content=\"D.digitactics · Organic Authority Architecture for Healthcare SaaS\"/><meta name=\"twitter:description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><link rel=\"icon\" href=\"/icon.svg?icon.90c9ba23.svg\" sizes=\"any\" type=\"image/svg+xml\"/><script>\n              window.dataLayer = window.dataLayer || [];\n              function gtag(){dataLayer.push(arguments);}\n              gtag('js', new Date());\n              gtag('config', 'G-EQMQGSTNR4');\n            </script><script src=\"/_next/static/chunks/a6dad97d9634a72d.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div role=\"region\" aria-label=\"Notifications (F8)\" tabindex=\"-1\" style=\"pointer-events:none\"><ol tabindex=\"-1\" class=\"fixed top-0 z-[100] flex max-h-screen w-full flex-col-reverse p-4 sm:bottom-0 sm:right-0 sm:top-auto sm:flex-col md:max-w-[420px]\"></ol></div><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><div class=\"min-h-screen flex flex-col\"><header class=\"border-b border-border bg-background\"><div class=\"container flex items-center justify-between py-5\"><a class=\"font-heading text-lg font-bold tracking-tight text-primary\" href=\"/\">D.digitactics</a><nav class=\"hidden md:flex items-center gap-8\"><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/\">Accueil</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-primary\" href=\"/services\">Services</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/oaa\">OAA</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/a-propos\">À propos</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/blog\">Blog</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/contact\">Contact</a><button class=\"text-sm font-semibold text-muted-foreground hover:text-primary transition-colors uppercase tracking-wide\" aria-label=\"Switch language\">EN</button></nav><div class=\"flex items-center gap-4 md:hidden\"><button class=\"text-sm font-semibold text-muted-foreground uppercase tracking-wide\" aria-label=\"Switch language\">EN</button><button class=\"text-primary\" aria-label=\"Menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></header><main class=\"flex-1\"><section class=\"py-24 md:py-32\"><div class=\"container max-w-3xl\"><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-3\">Services · Ce que nous vendons et ce que nous ne vendons pas</p><h1 class=\"text-4xl md:text-5xl font-black leading-tight tracking-tight mb-4\">Infrastructure architecturale, pas volume de contenu.</h1><p class=\"text-lg text-foreground leading-relaxed mb-16\">Digitactics vend une seule chose : la fondation structurelle dont les entreprises Healthcare SaaS ont besoin pour que leur contenu se capitalise. Ce n&#x27;est pas un abonnement SEO. Ce n&#x27;est pas une agence de contenu. Ce n&#x27;est pas un forfait de blog mensuel.</p></div><div class=\"container\"><div class=\"space-y-12\"><div class=\"border border-border p-8 md:p-10 bg-card\"><div class=\"grid md:grid-cols-2 gap-8\"><div><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Pour les entreprises Healthcare SaaS avec un programme de contenu actif qui ne se capitalise pas</p><h2 class=\"text-2xl font-bold mb-4\">L&#x27;Audit du Déficit de Confiance</h2><p class=\"text-foreground leading-relaxed mb-2\">Un diagnostic payant qui évalue votre site selon quatre dimensions : signaux de conformité réglementaire, architecture E-E-A-T, territoire de mots-clés et positionnement concurrentiel.</p><p class=\"text-sm text-muted-foreground leading-relaxed mb-6\">Ce n&#x27;est pas une proposition gratuite. C&#x27;est un produit. Chaque engagement commence ici.</p><p class=\"text-sm text-muted-foreground mt-1\">€3 000, crédités en intégralité sur votre engagement OAA si vous procédez dans les 30 jours</p></div><div><h3 class=\"text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-4\">Livrables</h3><ul class=\"space-y-2\"><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Audit des signaux de conformité réglementaire : ce que vous affirmez par rapport à ce que votre site démontre réellement</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Évaluation de l&#x27;architecture E-E-A-T : signaux d&#x27;autorité au niveau du site évalués selon les standards Google de la catégorie santé</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Carte du territoire de mots-clés : où vous possédez du terrain, où les concurrents l&#x27;ont pris, et où les écarts existent</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Évaluation du positionnement concurrentiel : comment votre infrastructure de contenu se compare à celle de vos concurrents directs</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Tableau de bord écrit et carte des priorités livrés à la fin</li></ul></div></div></div><div class=\"border border-border p-8 md:p-10 bg-card\"><div class=\"grid md:grid-cols-2 gap-8\"><div><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Pour les entreprises Healthcare SaaS prêtes à construire une infrastructure de contenu que leur équipe peut exécuter</p><h2 class=\"text-2xl font-bold mb-4\">Organic Authority Architecture</h2><p class=\"text-foreground leading-relaxed mb-2\">Un engagement d&#x27;infrastructure stratégique. Digitactics conçoit l&#x27;architecture. Votre équipe construit à partir du blueprint.</p><p class=\"text-sm text-muted-foreground leading-relaxed mb-6\">Digitactics ne rédige pas, ne publie pas et ne gère pas votre contenu. Nous sommes l&#x27;architecte, pas le constructeur.</p><p class=\"text-sm text-muted-foreground mt-1\">L&#x27;engagement commence avec l&#x27;Audit du Déficit de Confiance</p></div><div><h3 class=\"text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-4\">Livrables</h3><ul class=\"space-y-2\"><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Actif Pilier Central : le hub d&#x27;autorité à travers lequel chaque pièce de cluster transite</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Architecture de Cluster : un système de contenu cartographié organisé par niveau d&#x27;intention d&#x27;achat</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Couche de Validation Réglementaire : le cadre de citation et de conformité intégré dans chaque pièce</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Design de Routage d&#x27;Autorité Interne : architecture de liens qui construit l&#x27;autorité du site au lieu de la disperser</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Blueprint en 90 Jours : la séquence d&#x27;exécution, écrite pour que votre équipe la mette en oeuvre</li></ul></div></div></div></div><div class=\"container max-w-3xl mt-24\"><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-3\">Adéquation · Pour qui c&#x27;est fait</p><h2 class=\"text-3xl md:text-4xl font-black leading-tight tracking-tight mb-12\">Conçu pour un seul type d&#x27;entreprise.</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12\"><div><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-6\">Une bonne adéquation</p><ul class=\"space-y-4\"><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Les entreprises Healthcare SaaS avec un programme de contenu actif qui ne produit pas de croissance organique capitalisée</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Les entreprises opérant dans des environnements réglementés — HIPAA, PIPEDA, RGPD, UK GDPR — qui ont besoin que leur présence numérique le reflète</li><li class=\"text-foreground text-sm flex items-start gap-2\"><span class=\"text-accent mt-0.5\">+</span>Les équipes internes capables d&#x27;exécuter à partir d&#x27;un blueprint mais qui ont besoin de la bonne infrastructure pour construire</li></ul></div><div><p class=\"text-sm font-semibold uppercase tracking-widest text-muted-foreground mb-6\">Pas une adéquation</p><ul class=\"space-y-4\"><li class=\"text-muted-foreground text-sm flex items-start gap-2\"><span class=\"mt-0.5\">×</span>Les entreprises en phase de démarrage sans programme de contenu existant</li><li class=\"text-muted-foreground text-sm flex items-start gap-2\"><span class=\"mt-0.5\">×</span>Les entreprises qui cherchent une production ou une gestion de contenu mensuelle continue</li><li class=\"text-muted-foreground text-sm flex items-start gap-2\"><span class=\"mt-0.5\">×</span>Les entreprises en dehors de la catégorie Healthcare SaaS</li></ul></div></div></div><div class=\"mt-16 text-center\"><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary text-primary-foreground hover:bg-primary/90 h-11 rounded-md px-8 font-semibold\" href=\"/contact\">Commencer avec l&#x27;Audit</a></div></div></section></main><footer class=\"border-t border-border py-10\"><div class=\"container flex flex-col gap-4\"><a class=\"font-heading text-base font-bold text-primary\" href=\"/\">D.digitactics</a><p class=\"text-sm text-muted-foreground\">Architecture d&#x27;autorité pour le Healthcare SaaS.</p><div class=\"flex flex-wrap gap-5 text-sm text-muted-foreground\"><a class=\"hover:text-primary transition-colors\" href=\"/services\">Services</a><a class=\"hover:text-primary transition-colors\" href=\"/blog\">Blog</a><a class=\"hover:text-primary transition-colors\" href=\"/contact\">Contact</a><a class=\"hover:text-primary transition-colors\" href=\"/faq\">FAQ</a></div><p class=\"text-xs text-muted-foreground mt-2\">© 2025 D.digitactics. Tous droits réservés.</p></div></footer></div><!--$--><!--/$--><script src=\"/_next/static/chunks/0e1d4a177458003f.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[28739,[\\\"/_next/static/chunks/ad1e28e5e562f50f.js\\\",\\\"/_next/static/chunks/79a7563441b01c6b.js\\\",\\\"/_next/static/chunks/559c65e19c6c7a5a.js\\\"],\\\"default\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n5:I[47257,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ClientPageRoot\\\"]\\n6:I[64069,[\\\"/_next/static/chunks/ad1e28e5e562f50f.js\\\",\\\"/_next/static/chunks/79a7563441b01c6b.js\\\",\\\"/_next/static/chunks/559c65e19c6c7a5a.js\\\",\\\"/_next/static/chunks/14739d48f08353d6.js\\\",\\\"/_next/static/chunks/44a5e35cc6a50262.js\\\"],\\\"default\\\"]\\n9:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"OutletBoundary\\\"]\\na:\\\"$Sreact.suspense\\\"\\nc:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ViewportBoundary\\\"]\\ne:I[97367,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"MetadataBoundary\\\"]\\n10:I[68027,[],\\\"default\\\"]\\n:HL[\\\"/_next/static/chunks/e2c58c14e218d743.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"0:{\\\"P\\\":null,\\\"b\\\":\\\"qDi_Q2houFvzo7kJcV_0o\\\",\\\"c\\\":[\\\"\\\",\\\"services\\\"],\\\"q\\\":\\\"\\\",\\\"i\\\":false,\\\"f\\\":[[[\\\"\\\",{\\\"children\\\":[\\\"services\\\",{\\\"children\\\":[\\\"__PAGE__\\\",{}]}]},\\\"$undefined\\\",\\\"$undefined\\\",true],[[\\\"$\\\",\\\"$1\\\",\\\"c\\\",{\