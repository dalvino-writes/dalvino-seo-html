{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><!--qDi_Q2houFvzo7kJcV_0o--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/e2c58c14e218d743.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0e1d4a177458003f.js\"/><script src=\"/_next/static/chunks/f2f58a7e93290fbb.js\" async=\"\"></script><script src=\"/_next/static/chunks/b511d225fa117d63.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-941d9372f54a64f6.js\" async=\"\"></script><script src=\"/_next/static/chunks/ad1e28e5e562f50f.js\" async=\"\"></script><script src=\"/_next/static/chunks/79a7563441b01c6b.js\" async=\"\"></script><script src=\"/_next/static/chunks/559c65e19c6c7a5a.js\" async=\"\"></script><script src=\"/_next/static/chunks/ff1a16fafef87110.js\" async=\"\"></script><script src=\"/_next/static/chunks/d2be314c3ece3fbe.js\" async=\"\"></script><script src=\"/_next/static/chunks/f9244a96d86cbb21.js\" async=\"\"></script><script src=\"/_next/static/chunks/44a5e35cc6a50262.js\" async=\"\"></script><script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=G-EQMQGSTNR4\"></script><link rel=\"icon\" type=\"image/x-icon\" href=\"/favicon.ico\"/><link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/favicon-32x32.png\"/><link rel=\"icon\" type=\"image/png\" sizes=\"16x16\" href=\"/favicon-16x16.png\"/><link rel=\"apple-touch-icon\" sizes=\"180x180\" href=\"/apple-touch-icon.png\"/><link rel=\"manifest\" href=\"/site.webmanifest\"/><title>D.digitactics · Organic Authority Architecture for Healthcare SaaS</title><meta name=\"description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><meta name=\"author\" content=\"D.digitactics\"/><meta property=\"og:title\" content=\"D.digitactics · Organic Authority Architecture for Healthcare SaaS\"/><meta property=\"og:description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:site\" content=\"@digitactics\"/><meta name=\"twitter:title\" content=\"D.digitactics · Organic Authority Architecture for Healthcare SaaS\"/><meta name=\"twitter:description\" content=\"D.digitactics builds the content infrastructure Healthcare SaaS companies need to close their trust deficit and compound organic authority. Start with the Trust Deficit Audit.\"/><link rel=\"icon\" href=\"/icon.svg?icon.90c9ba23.svg\" sizes=\"any\" type=\"image/svg+xml\"/><script>\n              window.dataLayer = window.dataLayer || [];\n              function gtag(){dataLayer.push(arguments);}\n              gtag('js', new Date());\n              gtag('config', 'G-EQMQGSTNR4');\n            </script><script src=\"/_next/static/chunks/a6dad97d9634a72d.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><div role=\"region\" aria-label=\"Notifications (F8)\" tabindex=\"-1\" style=\"pointer-events:none\"><ol tabindex=\"-1\" class=\"fixed top-0 z-[100] flex max-h-screen w-full flex-col-reverse p-4 sm:bottom-0 sm:right-0 sm:top-auto sm:flex-col md:max-w-[420px]\"></ol></div><section aria-label=\"Notifications alt+T\" tabindex=\"-1\" aria-live=\"polite\" aria-relevant=\"additions text\" aria-atomic=\"false\"></section><div class=\"min-h-screen flex flex-col\"><header class=\"border-b border-border bg-background\"><div class=\"container flex items-center justify-between py-5\"><a class=\"font-heading text-lg font-bold tracking-tight text-primary\" href=\"/\">D.digitactics</a><nav class=\"hidden md:flex items-center gap-8\"><a class=\"text-sm font-medium transition-colors hover:text-primary text-primary\" href=\"/\">Accueil</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/services\">Services</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/oaa\">OAA</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/a-propos\">À propos</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/blog\">Blog</a><a class=\"text-sm font-medium transition-colors hover:text-primary text-muted-foreground\" href=\"/contact\">Contact</a><button class=\"text-sm font-semibold text-muted-foreground hover:text-primary transition-colors uppercase tracking-wide\" aria-label=\"Switch language\">EN</button></nav><div class=\"flex items-center gap-4 md:hidden\"><button class=\"text-sm font-semibold text-muted-foreground uppercase tracking-wide\" aria-label=\"Switch language\">EN</button><button class=\"text-primary\" aria-label=\"Menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button></div></div></header><main class=\"flex-1\"><section class=\"pt-20 pb-40 md:pt-28 md:pb-64\"><div class=\"container max-w-4xl\"><h1 class=\"text-4xl md:text-6xl lg:text-7xl font-black leading-[1] tracking-tighter mb-12 text-black\">Les entreprises Healthcare SaaS publient de plus en plus et progressent de moins en moins. Le problème est structurel, pas éditorial.</h1><p class=\"text-base md:text-lg text-black leading-relaxed mb-20 max-w-md\">Trafic organique plat. Dépassé par des concurrents qui publient moins. Conformité affirmée mais jamais prouvée. C&#x27;est le Déficit de Confiance. C&#x27;est un problème d&#x27;architecture.</p><div class=\"flex flex-col sm:flex-row gap-12\"><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 h-11 px-8 font-semibold bg-[#2D5A27] hover:bg-[#1e3d1a] text-white rounded-none shadow-none border-0\" href=\"/contact\">Obtenir votre Audit du Déficit de Confiance</a><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border h-11 px-8 font-semibold rounded-none border-black text-black bg-white hover:bg-black hover:text-white shadow-none\" href=\"/etudes-de-cas\">Voir comment OAA fonctionne</a></div></div></section><section class=\"py-20 md:py-32\"><div class=\"container max-w-4xl\"><p class=\"text-sm font-semibold tracking-widest uppercase text-[#2D5A27] mb-6\">Le Problème · Le Déficit de Confiance</p><h2 class=\"text-3xl md:text-5xl font-black leading-[1.1] tracking-tighter mb-12 text-black\">Vos concurrents ne rédigent pas mieux que vous. Ils structurent mieux que vous.</h2><div class=\"flex flex-col gap-6 max-w-2xl\"><p class=\"text-base md:text-lg text-black leading-relaxed\">Trafic organique plat malgré une publication régulière. Concurrents mieux positionnés sur des mots-clés que vous devriez dominer. Pages de conformité qui disent les bonnes choses sans convaincre personne.</p><p class=\"text-base md:text-lg text-black leading-relaxed\">Ce ne sont pas des échecs de qualité éditoriale. Ce sont des échecs structurels. Google applique ses signaux d&#x27;évaluation les plus stricts aux contenus de la catégorie santé. La plupart des entreprises Healthcare SaaS sont mesurées à ces standards sans le savoir.</p><p class=\"text-base md:text-lg text-black leading-relaxed\">Les entreprises qui gagnent en référencement organique dans ce secteur ne produisent pas de meilleurs contenus. Elles ont construit une meilleure architecture en dessous. Leurs contenus orientent correctement l&#x27;autorité, démontrent la crédibilité réglementaire et capturent l&#x27;intention d&#x27;achat à chaque étape du cycle de décision.</p><p class=\"text-base md:text-lg text-black leading-relaxed\">Cet écart structurel, c&#x27;est le Déficit de Confiance. C&#x27;est la distance entre ce qu&#x27;une entreprise Healthcare SaaS affirme et ce que son marché et les moteurs de recherche croient réellement.</p></div></div></section><section class=\"py-20 md:py-32 bg-black\"><div class=\"container max-w-4xl\"><p class=\"text-sm font-semibold tracking-widest uppercase text-[#2D5A27] mb-6\">Le Diagnostic · Pourquoi Cela Arrive</p><h2 class=\"text-3xl md:text-5xl font-black leading-[1.1] tracking-tighter mb-12 text-white\">Le Healthcare SaaS opère dans l&#x27;un des environnements de contenu les plus exigeants du web.</h2><div class=\"flex flex-col gap-6 max-w-2xl\"><p class=\"text-base md:text-lg text-white/80 leading-relaxed\">Google classe les contenus liés à la santé comme YMYL — Your Money or Your Life. Cette classification déclenche les signaux d&#x27;évaluation les plus stricts de tout l&#x27;index de recherche. E-E-A-T n&#x27;est pas une directive rédactionnelle ici. C&#x27;est un standard structurel appliqué au niveau du site.</p><p class=\"text-base md:text-lg text-white/80 leading-relaxed\">La plupart des entreprises Healthcare SaaS publient dans cet environnement avec un cadre conçu pour le SaaS généraliste. Aucun signal d&#x27;autorité au niveau du site. Aucune citation réglementaire au niveau des articles. Aucune architecture de contenu alignée sur le parcours réel des acheteurs.</p><p class=\"text-base md:text-lg text-white/80 leading-relaxed\">La conformité est l&#x27;exemple le plus parlant. Chaque concurrent du secteur affirme sa conformité HIPAA, PIPEDA, RGPD. Aucun ne la démontre dans son contenu. C&#x27;est dans cet écart que l&#x27;autorité organique se construit ou se perd.</p><p class=\"text-base md:text-lg text-white/80 leading-relaxed\">Les agences SEO généralistes ne traitent pas ce problème. Elles n&#x27;ont pas été conçues pour les secteurs réglementés. Elles optimisent pour le volume et la vélocité, pas pour les signaux de confiance structurels qui font bouger les classements dans la catégorie santé.</p></div></div></section><section class=\"py-20 md:py-28 border-t border-border\"><div class=\"container\"><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-3\">Organic Authority Architecture · Le Cadre</p><h2 class=\"text-3xl md:text-4xl font-bold mb-4 max-w-xl\">Un système conçu pour combler le déficit de confiance.</h2><p class=\"text-foreground text-lg mb-12 max-w-xl\">OAA comble l&#x27;écart entre ce que les entreprises Healthcare SaaS affirment et ce que Google et leur marché croient réellement. Trois piliers structurels le portent : l&#x27;Architecture E-E-A-T, une Couche de Contenu de Conformité Réglementaire, et un Cadre d&#x27;Intention à Trois Niveaux.</p><div class=\"grid grid-cols-1 md:grid-cols-2 gap-10 mb-12\"><div class=\"border border-border p-6 bg-card\"><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Pour les entreprises Healthcare SaaS avec un programme de contenu actif qui ne se capitalise pas</p><h3 class=\"text-xl font-bold mb-3\">L&#x27;Audit du Déficit de Confiance</h3><p class=\"text-foreground text-sm leading-relaxed mb-1\">Un diagnostic payant qui évalue votre site selon quatre dimensions : signaux de conformité réglementaire, architecture E-E-A-T, territoire de mots-clés et positionnement concurrentiel.</p><p class=\"text-foreground text-sm leading-relaxed underline mb-4\">Ce n&#x27;est pas une proposition gratuite. C&#x27;est un produit. Chaque engagement commence ici.</p></div><div class=\"border border-border p-6 bg-card\"><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Pour les entreprises Healthcare SaaS prêtes à construire une infrastructure de contenu que leur équipe peut exécuter</p><h3 class=\"text-xl font-bold mb-3\">Organic Authority Architecture</h3><p class=\"text-foreground text-sm leading-relaxed mb-1\">Un engagement d&#x27;infrastructure stratégique. Digitactics conçoit l&#x27;architecture. Votre équipe construit à partir du blueprint.</p><p class=\"text-foreground text-sm leading-relaxed underline mb-4\">Digitactics ne rédige pas, ne publie pas et ne gère pas votre contenu. Nous sommes l&#x27;architecte, pas le constructeur.</p></div></div><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 rounded-md px-8 font-semibold\" href=\"/services\">Voir comment OAA fonctionne →</a></div></section><section class=\"py-20 md:py-32\"><div class=\"container max-w-4xl\"><p class=\"text-sm font-semibold tracking-widest uppercase text-[#2D5A27] mb-6\">Le Résultat · Avant et Après</p><h2 class=\"text-3xl md:text-5xl font-black leading-[1.1] tracking-tighter mb-16 text-black\">La différence entre publier et capitaliser.</h2><div class=\"grid grid-cols-1 md:grid-cols-2 gap-12 mb-16\"><div><p class=\"text-sm font-semibold tracking-widest uppercase text-black/40 mb-6\">Avant OAA</p><ul class=\"flex flex-col gap-4\"><li class=\"text-base text-black/50 leading-relaxed pl-4 border-l border-black/20\">Publication régulière sans effet de capitalisation</li><li class=\"text-base text-black/50 leading-relaxed pl-4 border-l border-black/20\">Aucun signal d&#x27;autorité au niveau du site</li><li class=\"text-base text-black/50 leading-relaxed pl-4 border-l border-black/20\">Conformité déclarée sur une page statique, jamais démontrée dans le contenu</li><li class=\"text-base text-black/50 leading-relaxed pl-4 border-l border-black/20\">Stratégie de mots-clés mal alignée avec l&#x27;intention réelle des acheteurs</li><li class=\"text-base text-black/50 leading-relaxed pl-4 border-l border-black/20\">Acheteurs qui atterrissent chez des concurrents qui ont structuré leur contenu en premier</li></ul></div><div><p class=\"text-sm font-semibold tracking-widest uppercase text-[#2D5A27] mb-6\">Après OAA</p><ul class=\"flex flex-col gap-4\"><li class=\"text-base text-black leading-relaxed pl-4 border-l-2 border-[#2D5A27]\">Chaque article indexé renforce le pilier, chaque pilier renforce le cluster</li><li class=\"text-base text-black leading-relaxed pl-4 border-l-2 border-[#2D5A27]\">Signaux d&#x27;autorité au niveau du site en place et correctement orientés</li><li class=\"text-base text-black leading-relaxed pl-4 border-l-2 border-[#2D5A27]\">Crédibilité réglementaire intégrée au niveau des articles sur chaque contenu pertinent</li><li class=\"text-base text-black leading-relaxed pl-4 border-l-2 border-[#2D5A27]\">Contenu cartographié sur les trois niveaux du parcours de décision de l&#x27;acheteur</li><li class=\"text-base text-black leading-relaxed pl-4 border-l-2 border-[#2D5A27]\">Territoire organique qui croît sans dépense supplémentaire</li></ul></div></div><p class=\"text-sm text-black/50 leading-relaxed max-w-2xl\">L&#x27;infrastructure d&#x27;autorité se capitalise. Le trafic payant s&#x27;arrête dès que le budget s&#x27;arrête.</p></div></section><section class=\"py-20 md:py-32 bg-black\"><div class=\"container max-w-4xl\"><p class=\"text-sm font-semibold tracking-widest uppercase text-[#2D5A27] mb-6\">La Différence · Pourquoi Digitactics</p><h2 class=\"text-3xl md:text-5xl font-black leading-[1.1] tracking-tighter mb-16 text-white\">Conçu exclusivement pour le Healthcare SaaS. Rien d&#x27;autre.</h2><div class=\"flex flex-col divide-y divide-white/10 mb-16\"><div class=\"grid grid-cols-3 gap-8 pb-4\"><p class=\"text-xs font-semibold tracking-widest uppercase text-white/30\"></p><p class=\"text-xs font-semibold tracking-widest uppercase text-white/30\">Generic Agency</p><p class=\"text-xs font-semibold tracking-widest uppercase text-[#2D5A27]\">Digitactics</p></div><div class=\"grid grid-cols-3 gap-8 py-6\"><p class=\"text-sm font-semibold text-white/50 leading-relaxed\">Focus sectoriel</p><p class=\"text-sm text-white/40 leading-relaxed\">Cadres SEO généralistes appliqués à tout type de client</p><p class=\"text-sm text-white leading-relaxed\">Conçu exclusivement pour le Healthcare SaaS, où les standards YMYL s&#x27;appliquent</p></div><div class=\"grid grid-cols-3 gap-8 py-6\"><p class=\"text-sm font-semibold text-white/50 leading-relaxed\">Approche de la conformité</p><p class=\"text-sm text-white/40 leading-relaxed\">La conformité évoquée comme un sujet de contenu</p><p class=\"text-sm text-white leading-relaxed\">La crédibilité réglementaire traitée comme un signal de confiance structurel et démontrée au niveau des articles</p></div><div class=\"grid grid-cols-3 gap-8 py-6\"><p class=\"text-sm font-semibold text-white/50 leading-relaxed\">Stratégie de mots-clés</p><p class=\"text-sm text-white/40 leading-relaxed\">Recherche de mots-clés générique basée sur le volume et la difficulté</p><p class=\"text-sm text-white leading-relaxed\">Cartographie de territoire intégrant la dimension réglementaire, construite sur une base de données d&#x27;intelligence propriétaire</p></div><div class=\"grid grid-cols-3 gap-8 py-6\"><p class=\"text-sm font-semibold text-white/50 leading-relaxed\">Point d&#x27;entrée</p><p class=\"text-sm text-white/40 leading-relaxed\">Propositions gratuites et appels de découverte</p><p class=\"text-sm text-white leading-relaxed\">Diagnostic payant en premier. L&#x27;Audit est un produit, pas un argument de vente.</p></div><div class=\"grid grid-cols-3 gap-8 py-6\"><p class=\"text-sm font-semibold text-white/50 leading-relaxed\">Modèle d&#x27;engagement</p><p class=\"text-sm text-white/40 leading-relaxed\">Production et gestion de contenu en continu</p><p class=\"text-sm text-white leading-relaxed\">Architecture stratégique livrée une fois, conçue pour se capitaliser sans dépendance continue</p></div></div><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 h-11 px-8 font-semibold bg-[#2D5A27] hover:bg-[#1e3d1a] text-white rounded-none shadow-none border-0\" href=\"/contact\">Commencer avec l&#x27;Audit</a></div></section><section class=\"py-20 md:py-28 border-t border-border\"><div class=\"container\"><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-3\">Études de cas · Preuves de résultats</p><h2 class=\"text-3xl md:text-4xl font-bold mb-4 max-w-xl\">Ce que l&#x27;architecture d&#x27;autorité produit réellement.</h2><p class=\"text-foreground text-lg mb-12 max-w-xl\">Capitalisation organique, territoire de mots-clés acquis, pipeline entrant construit : chaque étude de cas documente l&#x27;impact structurel d&#x27;un engagement OAA correctement déployé.</p><div class=\"grid md:grid-cols-3 gap-8 mb-12\"><div class=\"border border-border p-6 bg-card\"><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Logiciel de gestion</p><h3 class=\"text-lg font-bold mb-3\">Startup SaaS B2B</h3><p class=\"text-foreground text-sm leading-relaxed mb-4\">Zéro trafic organique. Dépendance totale aux ads pour générer des leads.</p><ul class=\"space-y-1\"><li class=\"text-sm font-medium text-accent\">+340% de trafic organique en 3 mois</li><li class=\"text-sm font-medium text-accent\">15 mots-clés en première page Google</li><li class=\"text-sm font-medium text-accent\">Réduction de 40% du budget publicitaire</li></ul></div><div class=\"border border-border p-6 bg-card\"><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Ressources humaines</p><h3 class=\"text-lg font-bold mb-3\">Cabinet de conseil RH</h3><p class=\"text-foreground text-sm leading-relaxed mb-4\">Site vitrine sans contenu. Aucune stratégie de contenu ni de visibilité en ligne.</p><ul class=\"space-y-1\"><li class=\"text-sm font-medium text-accent\">+200% de demandes de contact en 2 mois</li><li class=\"text-sm font-medium text-accent\">Position 1 sur 3 requêtes locales</li><li class=\"text-sm font-medium text-accent\">Temps moyen sur le site multiplié par 2,5</li></ul></div><div class=\"border border-border p-6 bg-card\"><p class=\"text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2\">Beauté &amp; bien-être</p><h3 class=\"text-lg font-bold mb-3\">E-commerce cosmétiques bio</h3><p class=\"text-foreground text-sm leading-relaxed mb-4\">Trafic existant mais taux de conversion très faible. Pages produits génériques.</p><ul class=\"space-y-1\"><li class=\"text-sm font-medium text-accent\">+85% de taux de conversion sur les pages réécrites</li><li class=\"text-sm font-medium text-accent\">Taux de rebond réduit de 35%</li><li class=\"text-sm font-medium text-accent\">Panier moyen en hausse de 20%</li></ul></div></div><a class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 rounded-md px-8 font-semibold\" href=\"/etudes-de-cas\">Voir les études de cas</a></div></section><section class=\"py-20 md:py-28 border-t border-border\"><div class=\"container max-w-xl\"><p class=\"text-sm font-semibold uppercase tracking-widest text-accent mb-3\">Point d&#x27;Entrée · Audit du Déficit de Confiance</p><h2 class=\"text-3xl md:text-4xl font-bold mb-4\">Commencez par le diagnostic, pas par une proposition.</h2><p class=\"text-foreground text-lg mb-8\">L&#x27;Audit du Déficit de Confiance évalue vos signaux de conformité réglementaire, votre architecture E-E-A-T, votre territoire de mots-clés et votre positionnement concurrentiel. Ce qu&#x27;il produit : un tableau de bord écrit et une carte des priorités. €3 000, crédités en intégralité sur votre engagement OAA si vous procédez dans les 30 jours.</p><form class=\"flex flex-col sm:flex-row gap-3\"><input type=\"email\" class=\"flex h-10 w-full rounded-md border px-3 py-2 text-base ring-offset-background file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 md:text-sm flex-1 bg-card border-border\" placeholder=\"votre@email.com\"/><button class=\"inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md text-sm ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 [&amp;_svg]:pointer-events-none [&amp;_svg]:size-4 [&amp;_svg]:shrink-0 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 font-semibold\" type=\"submit\">Commencer avec l&#x27;Audit</button></form></div></section></main><footer class=\"border-t border-border py-10\"><div class=\"container flex flex-col gap-4\"><a class=\"font-heading text-base font-bold text-primary\" href=\"/\">D.digitactics</a><p class=\"text-sm text-muted-foreground\">Architecture d&#x27;autorité pour le Healthcare SaaS.</p><div class=\"flex flex-wrap gap-5 text-sm text-muted-foreground\"><a class=\"hover:text-primary transition-colors\" href=\"/services\">Services</a><a class=\"hover:text-primary transition-colors\" href=\"/blog\">Blog</a><a class=\"hover:text-primary transition-colors\" href=\"/contact\">Contact</a><a class=\"hover:text-primary transition-colors\" href=\"/faq\">FAQ</a></div><p class=\"text-xs text-muted-foreground mt-2\">© 2025 D.digitactics. Tous droits réservés.</p></div></footer></div><!--$--><!--/$--><script src=\"/_next/static/chunks/0e1d4a177458003f.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[28739,[\\\"/_next/static/chunks/ad1e28e5e562f50f.js\\\",\\\"/_next/static/chunks/79a7563441b01c6b.js\\\",\\\"/_next/static/chunks/559c65e19c6c7a5a.js\\\"],\\\"default\\\"]\\n3:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n4:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n5:I[41837,[\\\"/_next/static/chunks/ad1e28e5e562f50f.js\\\",\\\"/_next/static/chunks/79a7563441b01c6b.js\\\",\\\"/_next/static/chunks/559c65e19c6c7a5a.js\\\",\\\"/_next/static/chunks/f9244a96d86cbb21.js\\\",\\\"/_next/static/chunks/44a5e35cc6a50262.js\\\"],\